generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String      @id @default(cuid())
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  characters Character[]
  buildPlans BuildPlan[]
}

model Character {
  id              String           @id @default(cuid())
  characterId     Int              @unique
  characterName   String
  corporationId   Int?
  allianceId      Int?
  isMain          Boolean          @default(false)
  userId          String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  token           CharacterToken?
  ownedBlueprints OwnedBlueprint[]
  assets          Asset[]
  marketOrders    MarketOrder[]
  industryJobs    IndustryJob[]
}

model CharacterToken {
  id           String    @id @default(cuid())
  characterId  String    @unique
  accessToken  String
  refreshToken String
  expiresAt    DateTime
  scopes       String[]
  updatedAt    DateTime  @updatedAt
  character    Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model SdeType {
  id                Int                 @id
  name              String
  description       String?
  groupId           Int
  volume            Float?
  mass              Float?
  published         Boolean             @default(true)
  metaGroupId       Int?
  group             SdeGroup            @relation(fields: [groupId], references: [id])
  assets            Asset[]
  marketOrders      MarketOrder[]
  ownedBlueprints   OwnedBlueprint[]
  blueprintMaterials BlueprintMaterial[]
  blueprintProducts  BlueprintProduct[]
  buildPlanItems     BuildPlanItem[]
  buildPlanDecisions BuildPlanDecision[]
}

model SdeGroup {
  id         Int         @id
  name       String
  categoryId Int
  category   SdeCategory @relation(fields: [categoryId], references: [id])
  types      SdeType[]
}

model SdeCategory {
  id     Int        @id
  name   String
  groups SdeGroup[]
}

model Blueprint {
  typeId             Int                 @id
  maxProductionLimit Int
  activities         BlueprintActivity[]
}

model BlueprintActivity {
  id          Int               @id @default(autoincrement())
  blueprintId Int
  activity    ActivityType
  time        Int
  blueprint   Blueprint         @relation(fields: [blueprintId], references: [typeId])
  materials   BlueprintMaterial[]
  products    BlueprintProduct[]
  skills      BlueprintSkill[]

  @@unique([blueprintId, activity])
}

model BlueprintMaterial {
  id                  Int               @id @default(autoincrement())
  blueprintActivityId Int
  typeId              Int
  quantity            Int
  blueprintActivity   BlueprintActivity @relation(fields: [blueprintActivityId], references: [id])
  type                SdeType           @relation(fields: [typeId], references: [id])

  @@unique([blueprintActivityId, typeId])
}

model BlueprintProduct {
  id                  Int               @id @default(autoincrement())
  blueprintActivityId Int
  typeId              Int
  quantity            Int
  probability         Float?
  blueprintActivity   BlueprintActivity @relation(fields: [blueprintActivityId], references: [id])
  type                SdeType           @relation(fields: [typeId], references: [id])

  @@unique([blueprintActivityId, typeId])
}

model BlueprintSkill {
  id                  Int               @id @default(autoincrement())
  blueprintActivityId Int
  skillTypeId         Int
  level               Int
  blueprintActivity   BlueprintActivity @relation(fields: [blueprintActivityId], references: [id])

  @@unique([blueprintActivityId, skillTypeId])
}

model SdeRegion {
  id           Int              @id
  name         String
  solarSystems SdeSolarSystem[]
}

model SdeSolarSystem {
  id         Int          @id
  name       String
  regionId   Int
  security   Float
  region     SdeRegion    @relation(fields: [regionId], references: [id])
  stations   SdeStation[]
  structures Structure[]
}

model SdeStation {
  id            Int            @id
  name          String
  solarSystemId Int
  solarSystem   SdeSolarSystem @relation(fields: [solarSystemId], references: [id])
}

model IndustryJob {
  jobId           Int       @id
  characterId     String
  activityId      Int
  blueprintTypeId Int
  outputTypeId    Int
  runs            Int
  status          JobStatus
  startDate       DateTime
  endDate         DateTime
  completedDate   DateTime?
  facilityId      BigInt
  cost            Float?
  probability     Float?
  syncedAt        DateTime  @default(now())
  character       Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
}

model OwnedBlueprint {
  id                 String    @id @default(cuid())
  characterId        String
  itemId             BigInt
  typeId             Int
  locationId         BigInt
  runs               Int
  materialEfficiency Int
  timeEfficiency     Int
  syncedAt           DateTime  @default(now()) @updatedAt
  character          Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  type               SdeType   @relation(fields: [typeId], references: [id])

  @@unique([characterId, itemId])
}

model Structure {
  id            BigInt         @id
  name          String
  solarSystemId Int
  ownerId       Int
  typeId        Int?
  updatedAt     DateTime       @updatedAt
  solarSystem   SdeSolarSystem @relation(fields: [solarSystemId], references: [id])
}

model Asset {
  itemId      BigInt    @id
  characterId String
  typeId      Int
  locationId  BigInt
  quantity    Int
  isSingleton Boolean
  syncedAt    DateTime  @default(now()) @updatedAt
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  type        SdeType   @relation(fields: [typeId], references: [id])
}

model MarketOrder {
  orderId      BigInt    @id
  characterId  String
  typeId       Int
  locationId   BigInt
  volumeTotal  Int
  volumeRemain Int
  price        Float
  isBuyOrder   Boolean
  issued       DateTime
  duration     Int
  syncedAt     DateTime  @default(now()) @updatedAt
  character    Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  type         SdeType   @relation(fields: [typeId], references: [id])
}

model BuildPlan {
  id        String               @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     BuildPlanItem[]
  decisions BuildPlanDecision[]
}

model BuildPlanDecision {
  id       String    @id @default(cuid())
  planId   String
  typeId   Int
  decision String    // "buy" | "build"
  plan     BuildPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  type     SdeType   @relation(fields: [typeId], references: [id])

  @@unique([planId, typeId])
}

model BuildPlanItem {
  id                String    @id @default(cuid())
  planId            String
  typeId            Int
  quantity          Int
  completedQuantity Int       @default(0)
  plan              BuildPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  type              SdeType   @relation(fields: [typeId], references: [id])

  @@unique([planId, typeId])
}

enum ActivityType {
  MANUFACTURING
  RESEARCH_TIME
  RESEARCH_MATERIAL
  COPYING
  INVENTION
  REACTION
}

enum JobStatus {
  ACTIVE
  PAUSED
  READY
  DELIVERED
  CANCELLED
  REVERTED
}
